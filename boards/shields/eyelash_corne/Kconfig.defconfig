if SHIELD_EYELASH_CORNE_LEFT || SHIELD_EYELASH_CORNE_RIGHT

config ZMK_KEYBOARD_NAME
    default "Eyelash Corne"

config ZMK_SPLIT
    default y

endif # SHIELD_EYELASH_CORNE_LEFT || SHIELD_EYELASH_CORNE_RIGHT

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 1

if SHIELD_EYELASH_CORNE_LEFT

config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif # SHIELD_EYELASH_CORNE_LEFT

if SHIELD_EYELASH_CORNE_RIGHT

config ZMK_SPLIT_ROLE_PERIPHERAL
    default y

endif # SHIELD_EYELASH_CORNE_RIGHT
